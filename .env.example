# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/bplugins_support"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here-min-32-chars"

# Encryption key for credentials at rest (IMAP/SMTP passwords, API keys)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="generate-a-64-char-hex-key-here"

# Optional: Node environment
NODE_ENV="development"

# --- Docker / Coolify (only needed for docker-compose) ---
# POSTGRES_USER="support"
# POSTGRES_PASSWORD="change-me"
# POSTGRES_DB="support_desk"
